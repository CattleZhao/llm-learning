# Anthropic API (LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 记忆后端配置
MEMORY_BACKEND=local
MEMORY_STORE_PATH=data/memory

# PostgreSQL (如果使用)
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_memory

# Redis (如果使用)
# REDIS_URL=redis://localhost:6379/0

# 评估配置
ENABLE_EVALUATION=true
EVAL_DATASET_PATH=data/eval

# 工具验证
ENABLE_TOOL_VALIDATION=true

# JADX 配置 (HTTP 模式)
# MCP Server HTTP 地址
MCP_SERVER_URL=http://127.0.0.1:8651

# jadx-mcp-server 目录路径（用于启动 MCP Server）
JADX_MCP_SERVER_PATH=/root/Learn/jadx-mcp-server

# jadx-gui 可执行文件路径（用于自动打开 APK）
JADX_GUI_PATH=jadx-gui
# Windows 示例: JADX_GUI_PATH=C:\jadx\jadx-gui.exe

# JADX AI MCP Plugin 端口（默认 8650，通常不需要修改）
JADX_PLUGIN_PORT=8650

# MCP Server HTTP 端口（默认 8651，与 MCP Server 的 --port 参数一致）
MCP_SERVER_PORT=8651

# 日志
LOG_LEVEL=INFO
