# Anthropic API (LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 记忆后端配置
MEMORY_BACKEND=local
MEMORY_STORE_PATH=data/memory

# PostgreSQL (如果使用)
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_memory

# Redis (如果使用)
# REDIS_URL=redis://localhost:6379/0

# 评估配置
ENABLE_EVALUATION=true
EVAL_DATASET_PATH=data/eval

# 工具验证
ENABLE_TOOL_VALIDATION=true

# JADX 配置
JADX_MCP_SERVER_URL=http://localhost:8650
JADX_MCP_SERVER_PATH=/path/to/jadx-mcp-server
JADX_GUI_PATH=jadx-gui
# Windows 示例: JADX_GUI_PATH=C:\jadx\jadx-gui.exe

# 日志
LOG_LEVEL=INFO
