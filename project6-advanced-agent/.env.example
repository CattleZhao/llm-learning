# Anthropic API (LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 记忆后端配置
MEMORY_BACKEND=local
MEMORY_STORE_PATH=data/memory

# PostgreSQL (如果使用)
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_memory

# Redis (如果使用)
# REDIS_URL=redis://localhost:6379/0

# 评估配置
ENABLE_EVALUATION=true
EVAL_DATASET_PATH=data/eval

# 工具验证
ENABLE_TOOL_VALIDATION=true

# JADX MCP Server 配置
JADX_MCP_SERVER_URL=http://localhost:3000
JADX_PORT=8652
JADX_MCP_SERVER_PATH=/path/to/jadx-mcp-server
UV_PATH=uv

# jadx 可执行文件路径（MCP 不可用时的回退方案）
JADX_PATH=jadx

# JADX-GUI 路径（用于打开 APK 进行可视化）
JADX_GUI_PATH=/path/to/jadx-gui

# 日志
LOG_LEVEL=INFO
