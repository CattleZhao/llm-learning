# API Configuration - Choose one:

# Option 1: OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Option 2: Anthropic Claude API (via OpenAI-compatible endpoint)
# If you have an Anthropic API URL, set it like this:
# OPENAI_API_KEY=your_anthropic_api_key_here
# OPENAI_API_BASE=https://api.anthropic.com/v1  # or your custom Anthropic endpoint
# OPENAI_MODEL=claude-sonnet-4-20250514

# Option 3: Other OpenAI-compatible APIs (like local models)
# OPENAI_API_KEY=any_key
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_MODEL=your_model_name

# Code Execution
USE_DOCKER=false
CODE_EXECUTION_WORK_DIR=./outputs

# LLM Settings
TEMPERATURE=0.7
MAX_TOKENS=2000

# Agent Settings
AGENT_TIMEOUT=60
MAX_CONSECUTIVE_AUTO_REPLY=10

# Logging
LOG_LEVEL=INFO
