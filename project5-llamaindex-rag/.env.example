# Anthropic API (LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Hugging Face (嵌入模型)
HF_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBED_DEVICE=cpu

# 文档目录
DOCS_DIR=data/docs

# 存储目录
STORAGE_DIR=storage/chroma

# 索引参数
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=3
